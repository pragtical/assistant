+void entities_update(Level *level, Player *player, int camera_x) {
+    (void)camera_x;
+    
+    for (int i = 0; i < level->entity_count; i++) {
+        Entity *e = &level->entities[i];
+        
+        if (!e->active) continue;
+        
+        /* Handle dead enemies */
+        if (e->dead) {
+            e->dead_timer--;
+            if (e->dead_timer <= 0) {
+                e->active = false;
+            }
+            continue;
+        }
+        
+        /* Update based on entity type */
+        switch (e->type) {
+            case ENTITY_GOOMBA: {
+                /* Apply gravity */
+                apply_gravity(&e->vy, MAX_FALL_SPEED);
+                
+                /* Move on X */
+                float new_x = e->x + e->vx;
+                if (check_tile_collision_x(level, new_x, e->y, e->width, e->height, &new_x)) {
+                    e->vx = -e->vx;
+                    e->dir = (e->vx > 0) ? DIR_RIGHT : DIR_LEFT;
+                }
+                e->x = new_x;
+                
+                /* Move on Y */
+                float new_y = e->y + e->vy;
+                bool grounded = false;
+                if (check_tile_collision_y(level, e->x, new_y, e->width, e->height, &new_y, &grounded)) {
+                    e->vy = 0;
+                }
+                e->y = new_y;
+                
+                /* Animation */
+                e->anim_timer++;
+                if (e->anim_timer > 15) {
+                    e->anim_timer = 0;
+                    e->anim_frame = (e->anim_frame + 1) % 2;
+                }
+                
+                /* Player collision */
+                if (!player->dead && check_collision(
+                        player->x, player->y, player->width, player->height,
+                        e->x, e->y, e->width, e->height)) {
+                    
+                    /* Check if player is stomping */
+                    if (player->vy > 0 && player->y + player->height < e->y + e->height/2) {
+                        /* Stomp enemy */
+                        e->dead = true;
+                        e->dead_timer = STOMP_TIME;
+                        e->height = e->height / 2;
+                        player->vy = -4; /* Bounce */
+                        player->score += 100;
+                    } else if (player->invincible == 0) {
+                        /* Hurt player */
+                        player_hit(player);
+                    }
+                }
+                break;
+            }
+            
+            case ENTITY_COIN: {
+                /* Floating coin animation */
+                e->y += e->vy;
+                e->vy += 0.2f;
+                if (e->y > 12 * TILE_SIZE) {
+                    e->active = false;
+                }
+                
+                /* Player collects coin */
+                if (!player->dead && check_collision(
+                        player->x, player->y, player->width, player->height,
+                        e->x, e->y, e->width, e->height)) {
+                    e->active = false;
+                    player->coins++;
+                    player->score += 200;
+                }
+                break;
+            }
+            
+            case ENTITY_MUSHROOM: {
+                /* Apply gravity */
+                apply_gravity(&e->vy, MAX_FALL_SPEED);
+                
+                /* Move on X */
+                float new_x = e->x + e->vx;
+                if (check_tile_collision_x(level, new_x, e->y, e->width, e->height, &new_x)) {
+                    e->vx = -e->vx;
+                    e->dir = (e->vx > 0) ? DIR_RIGHT : DIR_LEFT;
+                }
+                e->x = new_x;
+                
+                /* Move on Y */
+                float new_y = e->y + e->vy;
+                bool grounded = false;
+                if (check_tile_collision_y(level, e->x, new_y, e->width, e->height, &new_y, &grounded)) {
+                    e->vy = 0;
+                }
+                e->y = new_y;
+                
+                /* Player collects mushroom */
+                if (!player->dead && check_collision(
+                        player->x, player->y, player->width, player->height,
+                        e->x, e->y, e->width, e->height)) {
+                    e->active = false;
+                    player_grow(player);
+                }
+                break;
+            }
+            
+            default:
+                break;
+        }
+    }
