+#include "sario.h"
+
+void player_init(Player *p) {
+    p->x = 3 * TILE_SIZE;
+    p->y = 10 * TILE_SIZE;
+    p->vx = 0;
+    p->vy = 0;
+    p->width = PLAYER_WIDTH;
+    p->height = PLAYER_HEIGHT;
+    p->orig_height = PLAYER_HEIGHT;
+    p->grounded = false;
+    p->powered = false;
+    p->growing = false;
+    p->shrinking = false;
+    p->grow_timer = 0;
+    p->invincible = 0;
+    p->dir = DIR_RIGHT;
+    p->anim_frame = 0;
+    p->anim_timer = 0;
+    p->coins = 0;
+    p->score = 0;
+    p->lives = 3;
+    p->dead = false;
+    p->dead_timer = 0;
+}
+
+void player_update(Player *p, const Level *level, int camera_x, bool *keys) {
+    (void)camera_x;
+    
+    if (p->dead) {
+        p->vy += GRAVITY;
+        if (p->vy > MAX_FALL_SPEED) p->vy = MAX_FALL_SPEED;
+        p->y += p->vy;
+        return;
+    }
+    
+    /* Handle growth animation */
+    if (p->growing) {
+        p->grow_timer++;
+        if (p->grow_timer > 30) {
+            p->growing = false;
+            p->height = PLAYER_TALL;
+        }
+        return;
+    }
+    
+    if (p->shrinking) {
+        p->grow_timer++;
+        if (p->grow_timer > 60) {
+            p->shrinking = false;
+            p->powered = false;
+            p->height = PLAYER_HEIGHT;
+            p->invincible = 0;
+        }
+        return;
+    }
+    
+    /* Invincibility frames */
+    if (p->invincible > 0) {
+        p->invincible--;
+    }
+    
+    /* Horizontal movement */
+    float move = 0;
+    if (keys[SDL_SCANCODE_LEFT] || keys[SDL_SCANCODE_A]) {
+        move = -1;
+        p->dir = DIR_LEFT;
+    }
+    if (keys[SDL_SCANCODE_RIGHT] || keys[SDL_SCANCODE_D]) {
+        move = 1;
+        p->dir = DIR_RIGHT;
+    }
+    
+    /* Apply movement with acceleration */
+    if (move != 0) {
+        p->vx += move * 0.5f;
+        if (p->vx > MOVE_SPEED) p->vx = MOVE_SPEED;
+        if (p->vx < -MOVE_SPEED) p->vx = -MOVE_SPEED;
+    } else {
+        /* Apply friction when no input */
+        if (p->vx > 0) {
+            p->vx -= 0.3f;
+            if (p->vx < 0) p->vx = 0;
+        } else if (p->vx < 0) {
+            p->vx += 0.3f;
+            if (p->vx > 0) p->vx = 0;
+        }
+    }
+    
+    /* Jumping */
+    if ((keys[SDL_SCANCODE_SPACE] || keys[SDL_SCANCODE_Z] || 
+         keys[SDL_SCANCODE_UP] || keys[SDL_SCANCODE_W]) && p->grounded) {
+        p->vy = JUMP_FORCE;
+        p->grounded = false;
+    }
+    
+    /* Apply gravity */
+    apply_gravity(&p->vy, MAX_FALL_SPEED);
+    
+    /* Move on X axis and check collision */
+    float new_x = p->x + p->vx;
+    if (check_tile_collision_x(level, new_x, p->y, p->width, p->height, &new_x)) {
+        p->vx = 0;
+    }
+    p->x = new_x;
+    
+    /* Clamp to level bounds */
+    if (p->x < 0) p->x = 0;
+    if (p->x > LEVEL_WIDTH * TILE_SIZE - p->width) {
+        p->x = LEVEL_WIDTH * TILE_SIZE - p->width;
+    }
+    
+    /* Move on Y axis and check collision */
+    float new_y = p->y + p->vy;
+    bool was_grounded = p->grounded;
+    p->grounded = false;
+    if (check_tile_collision_y(level, p->x, new_y, p->width, p->height, &new_y, &p->grounded)) {
+        if (p->vy > 0) {
+            /* Landing */
+            p->grounded = true;
+        }
+        p->vy = 0;
+    }
+    p->y = new_y;
+    
+    /* Check for question blocks hit from below */
+    if (!was_grounded && p->vy < 0) {
+        int head_y = (int)(p->y) / TILE_SIZE;
+        int foot_y = (int)(p->y + p->height - 1) / TILE_SIZE;
+        if (head_y != foot_y) {
+            /* Hit block above */
+            int check_x_left = (int)(p->x + 2) / TILE_SIZE;
+            int check_x_right = (int)(p->x + p->width - 2) / TILE_SIZE;
+            int check_y = head_y;
+            
+            for (int cx = check_x_left; cx <= check_x_right; cx++) {
+                if (cx >= 0 && cx < LEVEL_WIDTH && check_y >= 0 && check_y < LEVEL_HEIGHT) {
+                    uint8_t tile = level->tiles[check_y][cx];
+                    if (tile == TILE_QUESTION) {
+                        level->tiles[check_y][cx] = TILE_QUESTION_EMPTY;
+                        spawn_mushroom((Level*)level, cx * TILE_SIZE, check_y * TILE_SIZE);
+                        p->score += 100;
+                    } else if (tile == TILE_BRICK && p->powered) {
+                        level->tiles[check_y][cx] = TILE_EMPTY;
+                        p->score += 50;
+                    }
+                }
+            }
+        }
+    }
+    
+    /* Animation */
+    if (p->vx != 0 && p->grounded) {
+        p->anim_timer++;
+        if (p->anim_timer > 8) {
+            p->anim_timer = 0;
+            p->anim_frame = (p->anim_frame + 1) % 3;
+        }
+    } else {
+        p->anim_frame = 0;
+    }
+}
+
+void player_render(Game *game, const Player *p) {
+    int screen_x = (int)p->x - game->camera_x;
+    int screen_y = (int)p->y;
+    
+    /* Don't render if invincible and blinking */
+    if (p->invincible > 0 && (p->invincible / 4) % 2 == 0) {
+        return;
+    }
+    
+    /* Draw player (Sario) - red outfit */
+    Uint8 r = 200, g = 30, b = 30;
+    
+    if (p->dead) {
+        /* Death animation - just a simple sprite */
+        draw_filled_rect(game, screen_x, screen_y, p->width, p->height, r, g, b);
+        return;
+    }
+    
+    /* Body */
+    draw_filled_rect(game, screen_x + 2, screen_y + p->height/2, p->width - 4, p->height/2, r, g, b);
+    
+    /* Head */
+    draw_filled_rect(game, screen_x + 3, screen_y, p->width - 6, p->height/2 - 2, 255, 200, 150);
+    
+    /* Hat */
+    draw_filled_rect(game, screen_x + 2, screen_y, p->width - 4, 4, r, g, b);
+    
+    /* Eyes */
+    if (p->dir == DIR_RIGHT) {
+        draw_filled_rect(game, screen_x + p->width - 5, screen_y + 3, 3, 3, 0, 0, 0);
+    } else {
+        draw_filled_rect(game, screen_x + 2, screen_y + 3, 3, 3, 0, 0, 0);
+    }
+    
+    /* Overalls */
+    draw_filled_rect(game, screen_x + 3, screen_y + p->height/2 + 2, p->width - 6, 4, 30, 30, 150);
+    
+    /* Legs animation */
+    if (p->anim_frame == 1 && p->grounded) {
+        draw_filled_rect(game, screen_x + 2, screen_y + p->height - 4, 4, 4, 100, 50, 0);
+        draw_filled_rect(game, screen_x + p->width - 6, screen_y + p->height - 4, 4, 4, 100, 50, 0);
+    } else if (p->anim_frame == 2 && p->grounded) {
+        draw_filled_rect(game, screen_x + 4, screen_y + p->height - 4, 4, 4, 100, 50, 0);
+        draw_filled_rect(game, screen_x + p->width - 8, screen_y + p->height - 4, 4, 4, 100, 50, 0);
+    } else {
+        draw_filled_rect(game, screen_x + 3, screen_y + p->height - 4, 4, 4, 100, 50, 0);
+        draw_filled_rect(game, screen_x + p->width - 7, screen_y + p->height - 4, 4, 4, 100, 50, 0);
+    }
+}
+
+void player_hit(Player *p) {
+    if (p->dead || p->invincible > 0 || p->shrinking) {
+        return;
+    }
+    
+    if (p->powered) {
+        /* Shrink instead of dying */
+        p->shrinking = true;
+        p->grow_timer = 0;
+        p->invincible = INVINCIBLE_TIME;
+    } else {
+        /* Die */
+        p->dead = true;
+        p->dead_timer = 120;
+        p->vy = -6; /* Death hop */
+    }
+}
+
+void player_grow(Player *p) {
+    if (p->powered || p->growing) {
+        p->score += 1000;
+        return;
+    }
+    p->growing = true;
+    p->grow_timer = 0;
+    p->powered = true;
+}

