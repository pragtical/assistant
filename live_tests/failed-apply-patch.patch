+void apply_friction(float *vx, float friction) {
+    if (*vx > 0) {
+        *vx -= friction;
+        if (*vx < 0) *vx = 0;
+    } else if (*vx < 0) {
+        *vx += friction;
+        if (*vx > 0) *vx = 0;
+    }
