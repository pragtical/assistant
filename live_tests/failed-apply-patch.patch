+#include "sario.h"
+
+bool check_collision(float x1, float y1, int w1, int h1,
+                     float x2, float y2, int w2, int h2) {
+    return (x1 < x2 + w2 && x1 + w1 > x2 &&
+            y1 < y2 + h2 && y1 + h1 > y2);
+}
+
+bool check_tile_collision(const Level *level, float x, float y, int w, int h) {
+    /* Check all four corners */
+    int left = (int)x / TILE_SIZE;
+    int right = (int)(x + w - 1) / TILE_SIZE;
+    int top = (int)y / TILE_SIZE;
+    int bottom = (int)(y + h - 1) / TILE_SIZE;
+    
+    for (int ty = top; ty <= bottom; ty++) {
+        for (int tx = left; tx <= right; tx++) {
+            if (tx < 0 || tx >= LEVEL_WIDTH || ty < 0 || ty >= LEVEL_HEIGHT) {
+                continue;
+            }
+            uint8_t tile = level->tiles[ty][tx];
+            if (tile != TILE_EMPTY && tile != TILE_COIN) {
+                return true;
+            }
+        }
+    }
+    return false;
+}
+
+bool check_tile_collision_x(const Level *level, float x, float y, int w, int h, float *new_x) {
+    int left = (int)x / TILE_SIZE;
+    int right = (int)(x + w - 1) / TILE_SIZE;
+    int top = (int)y / TILE_SIZE;
+    int bottom = (int)(y + h - 1) / TILE_SIZE;
+    
+    bool collided = false;
+    
+    for (int ty = top; ty <= bottom; ty++) {
+        for (int tx = left; tx <= right; tx++) {
+            if (tx < 0 || tx >= LEVEL_WIDTH || ty < 0 || ty >= LEVEL_HEIGHT) {
+                continue;
+            }
+            uint8_t tile = level->tiles[ty][tx];
+            if (tile != TILE_EMPTY && tile != TILE_COIN) {
+                /* Calculate tile boundaries */
+                float tile_left = tx * TILE_SIZE;
+                float tile_right = (tx + 1) * TILE_SIZE;
+                
+                if (x + w > tile_left && x < tile_right) {
+                    collided = true;
+                    if (x < tile_left) {
+                        *new_x = tile_left - w;
+                    } else {
+                        *new_x = tile_right;
+                    }
+                    return collided;
+                }
+            }
+        }
+    }
+    return collided;
+}
+
+bool check_tile_collision_y(const Level *level, float x, float y, int w, int h, float *new_y, bool *grounded) {
+    int left = (int)x / TILE_SIZE;
+    int right = (int)(x + w - 1) / TILE_SIZE;
+    int top = (int)y / TILE_SIZE;
+    int bottom = (int)(y + h - 1) / TILE_SIZE;
+    
+    bool collided = false;
+    *grounded = false;
+    
+    for (int ty = top; ty <= bottom; ty++) {
+        for (int tx = left; tx <= right; tx++) {
+            if (tx < 0 || tx >= LEVEL_WIDTH || ty < 0 || ty >= LEVEL_HEIGHT) {
+                continue;
+            }
+            uint8_t tile = level->tiles[ty][tx];
+            if (tile != TILE_EMPTY && tile != TILE_COIN) {
+                /* Calculate tile boundaries */
+                float tile_top = ty * TILE_SIZE;
+                float tile_bottom = (ty + 1) * TILE_SIZE;
+                
+                if (y + h > tile_top && y < tile_bottom) {
+                    collided = true;
+                    if (y < tile_top) {
+                        *new_y = tile_top - h;
+                        *grounded = true;
+                    } else {
+                        *new_y = tile_bottom;
+                    }
+                    return collided;
+                }
+            }
+        }
+    }
+    return collided;
+}

