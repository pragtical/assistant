+void level_render(Game *game, const Level *level, int camera_x) {
+    /* Calculate visible tile range */
+    int start_x = camera_x / TILE_SIZE;
+    int end_x = (camera_x + SCREEN_WIDTH) / TILE_SIZE + 1;
+    
+    if (start_x < 0) start_x = 0;
+    if (end_x > LEVEL_WIDTH) end_x = LEVEL_WIDTH;
+    
+    /* Render tiles */
+    for (int y = 0; y < LEVEL_HEIGHT; y++) {
+        for (int x = start_x; x < end_x; x++) {
+            uint8_t tile = level->tiles[y][x];
+            if (tile == TILE_EMPTY) continue;
+            
+            int screen_x = x * TILE_SIZE - camera_x;
+            int screen_y = y * TILE_SIZE;
+            
+            switch (tile) {
+                case TILE_GROUND:
+                    draw_filled_rect(game, screen_x, screen_y, TILE_SIZE, TILE_SIZE, 
+                                   139, 90, 43);
+                    /* Grass top */
+                    draw_filled_rect(game, screen_x, screen_y, TILE_SIZE, 4, 
+                                   100, 180, 50);
+                    break;
+                    
+                case TILE_BRICK:
+                    draw_filled_rect(game, screen_x, screen_y, TILE_SIZE, TILE_SIZE, 
+                                   180, 100, 50);
+                    /* Brick pattern */
+                    draw_rect(game, screen_x, screen_y, TILE_SIZE, TILE_SIZE, 
+                            100, 60, 30);
+                    draw_rect(game, screen_x + TILE_SIZE/2, screen_y, 2, TILE_SIZE, 
+                            100, 60, 30);
+                    draw_rect(game, screen_x, screen_y + TILE_SIZE/2, TILE_SIZE, 2, 
+                            100, 60, 30);
+                    break;
+                    
+                case TILE_QUESTION:
+                    draw_filled_rect(game, screen_x, screen_y, TILE_SIZE, TILE_SIZE, 
+                                   255, 200, 50);
+                    /* Question mark */
+                    draw_filled_rect(game, screen_x + 6, screen_y + 3, 4, 4, 
