+void level_load_1_1(Level *level) {
+    /* Clear level */
+    memset(level->tiles, TILE_EMPTY, sizeof(level->tiles));
+    level->entity_count = 0;
+    
+    /* Ground - almost entire level */
+    for (int x = 0; x < LEVEL_WIDTH; x++) {
+        /* Gaps in the ground */
+        if ((x >= 69 && x <= 70) || (x >= 86 && x <= 87) || 
+            (x >= 147 && x <= 148) || (x >= 151 && x <= 152)) {
