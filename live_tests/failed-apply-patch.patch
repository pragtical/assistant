+bool level_get_tile(const Level *level, int x, int y) {
+    if (x < 0 || x >= LEVEL_WIDTH || y < 0 || y >= LEVEL_HEIGHT) {
+        return false;
+    }
+    uint8_t tile = level->tiles[y][x];
+    return tile != TILE_EMPTY && tile != TILE_COIN;
+}
+
+void level_set_tile(Level *level, int x, int y, TileType type) {
+    if (x >= 0 && x < LEVEL_WIDTH && y >= 0 && y < LEVEL_HEIGHT) {
+        level->tiles[y][x] = (uint8_t)type;
+    }
