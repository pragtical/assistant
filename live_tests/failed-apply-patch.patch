+static bool input_keys[SDL_NUM_SCANCODES] = {false};
+
+void game_init(Game *game) {
+    game->state = STATE_TITLE;
+    game->camera_x = 0;
+    game->time_left = 400;
+    game->frame_count = 0;
+    game->running = true;
+    game->last_time = SDL_GetTicks();
+    game->title_timer = 0;
+    game->input_keys = input_keys;
+    
+    level_init(&game->level);
+    level_load_1_1(&game->level);
+    player_init(&game->player);
+    entities_init(&game->level);
+}
+
+void game_reset(Game *game) {
+    game->state = STATE_PLAYING;
+    game->camera_x = 0;
+    game->time_left = 400;
+    game->player.lives--;
+    player_init(&game->player);
+    game->player.lives = 3; /* Keep lives on respawn */
+    level_load_1_1(&game->level);
+    entities_init(&game->level);
+}
+
+void game_update(Game *game, float dt) {
+    (void)dt;
+    
+    /* Title screen */
+    if (game->state == STATE_TITLE) {
+        game->title_timer++;
+        if (input_is_pressed(game->input_keys, SDLK_RETURN) ||
+            input_is_pressed(game->input_keys, SDLK_SPACE)) {
+            game->state = STATE_PLAYING;
+            player_init(&game->player);
+            entities_init(&game->level);
+        }
+        return;
+    }
+    
+    /* Game over or victory - wait for input */
+    if (game->state == STATE_GAME_OVER || game->state == STATE_VICTORY) {
+        if (input_is_pressed(game->input_keys, SDLK_RETURN) ||
+            input_is_pressed(game->input_keys, SDLK_SPACE)) {
+            game->player.lives = 3;
+            game_reset(game);
+        }
+        return;
+    }
+    
+    /* Update timer (every 60 frames) */
+    game->frame_count++;
+    if (game->frame_count % 60 == 0 && game->time_left > 0) {
+        game->time_left--;
+        if (game->time_left == 0) {
+            player_hit(&game->player);
+        }
+    }
+    
+    /* Update player */
+    player_update(&game->player, &game->level, game->camera_x, game->input_keys);
+    
+    /* Update camera to follow player */
+    int target_camera = game->player.x - SCREEN_WIDTH / 3;
+    if (target_camera < 0) target_camera = 0;
+    if (target_camera > (LEVEL_WIDTH * TILE_SIZE) - SCREEN_WIDTH) {
+        target_camera = (LEVEL_WIDTH * TILE_SIZE) - SCREEN_WIDTH;
+    }
+    game->camera_x = target_camera;
+    
+    /* Update entities */
+    entities_update(&game->level, &game->player, game->camera_x);
+    
+    /* Check for flag pole collision (victory) */
+    int player_tile_x = game->player.x / TILE_SIZE;
+    int player_tile_y = game->player.y / TILE_SIZE;
+    if (player_tile_x >= 0 && player_tile_x < LEVEL_WIDTH &&
+        player_tile_y >= 0 && player_tile_y < LEVEL_HEIGHT) {
+        uint8_t tile = game->level.tiles[player_tile_y][player_tile_x];
+        if (tile == TILE_FLAG_POLE || tile == TILE_FLAG_TOP) {
+            game->state = STATE_VICTORY;
+            game->player.score += game->time_left * 50;
+        }
+    }
+    
+    /* Check for falling off the world */
+    if (game->player.y > LEVEL_HEIGHT * TILE_SIZE) {
+        player_hit(&game->player);
+    }
+    
+    /* Handle player death */
+    if (game->player.dead) {
+        game->player.dead_timer--;
+        if (game->player.dead_timer <= 0) {
+            if (game->player.lives > 0) {
+                game_reset(game);
+            } else {
+                game->state = STATE_GAME_OVER;
+            }
+        }
+    }
+}
