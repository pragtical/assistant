+#include "sario.h"
+
+int main(int argc, char *argv[]) {
+    (void)argc;
+    (void)argv;
+    
+    Game game = {0};
+    
+    if (!graphics_init(&game)) {
+        SDL_Log("Failed to initialize graphics");
+        return 1;
+    }
+    
+    game_init(&game);
+    
+    /* Main game loop */
+    while (game.running) {
+        Uint32 current_time = SDL_GetTicks();
+        float dt = (current_time - game.last_time) / 1000.0f;
+        game.last_time = current_time;
+        
+        /* Cap delta time to prevent physics explosions */
+        if (dt > 0.1f) dt = 0.1f;
+        
+        SDL_Event event;
+        while (SDL_PollEvent(&event)) {
+            if (event.type == SDL_QUIT) {
+                game.running = false;
+            } else if (event.type == SDL_KEYDOWN) {
+                if (event.key.keysym.sym == SDLK_ESCAPE) {
+                    game.running = false;
+                }
+                input_update(game.input_keys, &event);
+            } else if (event.type == SDL_KEYUP) {
+                input_update(game.input_keys, &event);
+            }
+        }
+        
+        game_update(&game, dt);
+        game_render(&game);
+        
+        game.frame_count++;
+    }
+    
+    game_cleanup(&game);
+    graphics_cleanup(&game);
+    
+    return 0;
+}

